# Generate once before first start:
# docker compose run --rm --no-deps --build backend php artisan key:generate --show
APP_KEY=

APP_NAME="Call Center Operator"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

BCRYPT_ROUNDS=12
API_TOKEN_TTL_MINUTES=480

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=call_center
DB_USERNAME=call_center
DB_PASSWORD=call_center
DB_ROOT_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=redis
CACHE_STORE=redis
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=callcenter
REVERB_APP_KEY=local-reverb-key-change-me
REVERB_APP_SECRET=local-reverb-secret-change-me
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# Telegram — use webhook in production or polling for local real-chat testing.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_WEBHOOK_URL=
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_POLLING_LIMIT=20
DEV_TELEGRAM_REPLAY_ENABLED=false
DEV_TELEGRAM_REPLAY_SECRET=
