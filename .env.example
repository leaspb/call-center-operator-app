# Application
APP_NAME="Call Center Operator"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Moscow

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=call_center
DB_USERNAME=call_center
DB_PASSWORD=call_center

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Queue / cache / sessions
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=database

# Laravel Reverb / broadcasting
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=callcenter
REVERB_APP_KEY=local-reverb-key-change-me
REVERB_APP_SECRET=local-reverb-secret-change-me
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Telegram Bot
TELEGRAM_FAKE=true
# Backend-only secrets. Never expose these to frontend or commit real values.
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_WEBHOOK_URL=https://your-public-domain.example/api/v1/telegram/webhook

# Frontend
FRONTEND_API_URL=http://localhost/api/v1
FRONTEND_REVERB_HOST=localhost
FRONTEND_REVERB_PORT=8080
FRONTEND_REVERB_SCHEME=http

# Vite browser-exposed frontend variables
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_REVERB_APP_KEY=local-reverb-key-change-me
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
