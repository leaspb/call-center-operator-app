# Android emulator defaults. Copy to `.env.android` before running `npm run android:sync`.
# Android Studio emulator reaches the host machine through 10.0.2.2.
VITE_API_BASE_URL=http://10.0.2.2:8000/api/v1
VITE_REVERB_APP_KEY=local-reverb-key-change-me
VITE_REVERB_HOST=10.0.2.2
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
